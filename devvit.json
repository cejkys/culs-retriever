{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "culs-retriever",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "media": {
    "dir": "assets"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": ["api.reddit.com", "aqkfaqvtorfbmgekskle.supabase.co"]
    },
    "reddit": {
      "enable": true,
      "scope": "user"
    },
    "redis": true
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "culs-retriever",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "settings": {
    "global": {
      "supabase_url": {
        "type": "string",
        "label": "Supabase URL",
        "helpText": "Project URL, e.g. https://<project-ref>.supabase.co"
      },
      "supabase_service_role_key": {
        "type": "string",
        "label": "Supabase Service Role Key",
        "helpText": "Server-side secret key used for archive writes/reads.",
        "isSecret": true
      },
      "supabase_table": {
        "type": "string",
        "label": "Supabase Table",
        "helpText": "Archive table name.",
        "defaultValue": "reddit_posts"
      },
      "archive_fetch_limit": {
        "type": "number",
        "label": "Archive Fetch Limit",
        "helpText": "Max archived rows loaded per query.",
        "defaultValue": 5000
      }
    }
  },
  "dev": {
    "subreddit": "culs_retriever_dev"
  }
}
