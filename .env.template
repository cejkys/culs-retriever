DEVVIT_SUBREDDIT=r/my_subreddit

# Optional: Supabase archive for persistent Reddit post storage.
# Example: https://<project-ref>.supabase.co
SUPABASE_URL=
# Optional client-side key reference (not used by current server integration).
SUPABASE_PUBLISHABLE_KEY=
# Use the service role key (server-side only, never expose in client code).
SUPABASE_SERVICE_ROLE_KEY=
# Optional table name (default: reddit_posts)
SUPABASE_TABLE=reddit_posts
# Optional number of recent archived rows loaded per request (default: 5000, max: 10000)
ARCHIVE_FETCH_LIMIT=5000
# Optional: set to 1 to skip automatic Devvit settings sync during launch.
# SKIP_DEVVIT_SETTINGS_SYNC=1
# Optional direct Postgres URL for external tools/migrations.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres
